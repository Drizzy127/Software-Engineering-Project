<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane fx:controller="Controllers.RegisterController"
          xmlns:fx="http://javafx.com/fxml"
          hgap="10" vgap="10">

    <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="emailField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <PasswordField fx:id="passwordField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Department:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <ComboBox fx:id="departmentBox" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Button text="Register" onAction="#handleRegister"
            GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label fx:id="messageLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
</GridPane>